{
  "name": "jootacee-ops",
  "version": "0.1.0",
  "private": true,
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "tsc --noEmit"
    ]
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "analyze": "ANALYZE=true next build",
    "convert-icons": "node scripts/convert-icons.js",
    "generate:rss": "node scripts/generate-rss.mjs",
    "generate:og": "node scripts/generate-og.mjs",
    "generate:sitemap": "node scripts/generate-sitemap.mjs",
    "validate:content": "node scripts/validate-content.mjs",
    "fetch:github": "node scripts/fetch-github-data.mjs",
    "fetch:lighthouse": "node scripts/fetch-lighthouse.mjs",
    "postbuild": "node scripts/fetch-github-data.mjs && node scripts/fetch-lighthouse.mjs && node scripts/convert-icons.js && node scripts/beautify-html.mjs && node scripts/generate-sitemap.mjs && node scripts/generate-rss.mjs && node scripts/generate-og.mjs && pagefind --site dist --output-path dist/_pagefind",
    "clean": "rm -rf dist",
    "prepare": "husky"
  },
  "dependencies": {
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "^16.2.6",
    "@react-oauth/google": "^0.13.5",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@sentry/nextjs": "^10.55.0",
    "@supabase/supabase-js": "^2.106.2",
    "@types/jszip": "^3.4.0",
    "@uiw/react-md-editor": "^4.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "gray-matter": "^4.0.3",
    "jszip": "^3.10.1",
    "lenis": "^1.3.23",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@next/bundle-analyzer": "^16.2.6",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/ui": "^4.1.6",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "http-server": "^14.1.1",
    "husky": "^9.1.7",
    "js-beautify": "^1.15.4",
    "jsdom": "^29.1.1",
    "lighthouse": "^13.3.0",
    "lint-staged": "^17.0.5",
    "pagefind": "^1.5.2",
    "satori": "^0.26.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.6",
    "zod": "^4.4.3"
  }
}
