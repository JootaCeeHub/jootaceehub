{
  "ci": {
    "collect": {
      "staticDistDir": "./dist",
      "url": [
        "http://localhost/en/index.html",
        "http://localhost/es/index.html",
        "http://localhost/en/systems/index.html",
        "http://localhost/en/intelligence/index.html"
      ],
      "budgets": [
        {
          "path": "/en/",
          "resourceSizes": [
            { "resourceType": "script",     "budget": 700 },
            { "resourceType": "stylesheet", "budget": 50  },
            { "resourceType": "image",      "budget": 300 },
            { "resourceType": "font",       "budget": 100 },
            { "resourceType": "total",      "budget": 1200 }
          ],
          "timings": [
            { "metric": "first-contentful-paint",   "budget": 2000 },
            { "metric": "largest-contentful-paint", "budget": 3500 },
            { "metric": "total-blocking-time",      "budget": 600  },
            { "metric": "interactive",              "budget": 5000 }
          ]
        },
        {
          "path": "/es/",
          "resourceSizes": [
            { "resourceType": "script", "budget": 700 },
            { "resourceType": "total",  "budget": 1200 }
          ],
          "timings": [
            { "metric": "first-contentful-paint",   "budget": 2000 },
            { "metric": "largest-contentful-paint", "budget": 3500 },
            { "metric": "total-blocking-time",      "budget": 600  }
          ]
        },
        {
          "path": "/en/systems/",
          "resourceSizes": [
            { "resourceType": "script", "budget": 900 },
            { "resourceType": "total",  "budget": 1500 }
          ],
          "timings": [
            { "metric": "largest-contentful-paint", "budget": 4000 },
            { "metric": "total-blocking-time",      "budget": 800  }
          ]
        },
        {
          "path": "/en/intelligence/",
          "resourceSizes": [
            { "resourceType": "script", "budget": 900 },
            { "resourceType": "total",  "budget": 1500 }
          ],
          "timings": [
            { "metric": "largest-contentful-paint", "budget": 4000 },
            { "metric": "total-blocking-time",      "budget": 800  }
          ]
        }
      ],
      "numberOfRuns": 3,
      "settings": {
        "preset": "desktop",
        "throttlingMethod": "simulate",
        "screenEmulation": {
          "mobile": false,
          "width": 1440,
          "height": 900,
          "deviceScaleFactor": 1
        }
      }
    },
    "assert": {
      "assertions": {
        "categories:performance":    ["error", {"minScore": 0.55}],
        "categories:accessibility":  ["error", {"minScore": 0.95}],
        "categories:best-practices": ["warn",  {"minScore": 0.90}],
        "categories:seo":            ["error", {"minScore": 1.00}],
        "first-contentful-paint":    ["warn",  {"maxNumericValue": 2000}],
        "largest-contentful-paint":  ["error", {"maxNumericValue": 4000}],
        "total-blocking-time":       ["error", {"maxNumericValue": 800}],
        "cumulative-layout-shift":   ["error", {"maxNumericValue": 0.1}],
        "interactive":               ["warn",  {"maxNumericValue": 5000}],
        "interaction-to-next-paint": ["warn",  {"maxNumericValue": 500}],
        "uses-rel-preconnect":       ["warn",  {"maxLength": 0}],
        "uses-text-compression":     ["warn",  {"maxLength": 0}],
        "uses-optimized-images":     ["warn",  {"maxLength": 0}],
        "render-blocking-resources": ["warn",  {"maxLength": 0}]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
