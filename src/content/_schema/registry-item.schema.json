{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "registry-item.schema.json",
  "title": "Registry Item (JSON)",
  "description": "Schema for src/content/{projects,labs,systems,resources,collections}/*.json",
  "type": "object",
  "required": ["id", "title", "slug", "description", "type", "status", "locale", "publishedAt", "updatedAt"],
  "additionalProperties": true,
  "properties": {
    "id":          { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "title":       { "type": "string", "minLength": 1, "maxLength": 120 },
    "slug":        { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "description": { "type": "string", "minLength": 10, "maxLength": 300 },
    "type": {
      "type": "string",
      "enum": ["article", "project", "research", "lab", "system", "resource", "collection"]
    },
    "status":      { "type": "string", "enum": ["draft", "published", "archived", "deprecated"] },
    "locale":      { "type": "string", "enum": ["en", "es"] },
    "tags":        { "type": "array", "items": { "type": "string" }, "default": [] },
    "publishedAt": { "type": "string", "format": "date-time" },
    "updatedAt":   { "type": "string", "format": "date-time" },
    "featured":    { "type": "boolean", "default": false },
    "coverImage":  { "type": ["string", "null"], "default": null },
    "url":         { "type": ["string", "null"], "default": null },
    "repoUrl":     { "type": ["string", "null"], "default": null }
  }
}
